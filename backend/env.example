## Backend environment configuration
# Copy this file to `.env` (same directory) and populate with your project-specific values.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_USE_STUB=false

PORT=3001

# Frontend origin(s) allowed to call this API. Comma separate multiple origins.
# Defaults to http://localhost:5173 when unset.
CLIENT_ORIGIN=

# Google Gemini configuration for AI activity suggestions
GEMINI_API_KEY=
# Optional: override the default model (defaults to gemini-1.5-flash)
GEMINI_MODEL=

# Top-k compatibility cache (Redis). Reduces recomputation via profile versioning.
# When set, compatibility scores for each user's top matches are cached; only recomputed for new/updated users.
REDIS_URL=
# Optional: number of top matches to cache per user (default 10)
# COMPATIBILITY_TOP_K=10
# Optional: cache TTL in seconds (default 86400 = 24h)
# COMPATIBILITY_CACHE_TTL_SECONDS=86400

